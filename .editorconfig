root = true

# 2-space indent is the default everywhere unless a type overrides it.
[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8
indent_style = space
indent_size = 2

# shfmt honors these from editorconfig when no -i/-ci flag is forced.
switch_case_indent = true

# Markdown list continuation indent is marker-width-driven (3 spaces
# under "1. "), not a fixed size. Leave indent size unenforced.
[*.md]
indent_size = unset

[justfile]
indent_size = 4
