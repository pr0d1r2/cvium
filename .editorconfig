root = true

[*]
end_of_line = lf
insert_final_newline = true
trim_trailing_whitespace = true
charset = utf-8

[*.{sh,bats}]
indent_style = space
indent_size = 4

[*.nix]
indent_style = space
indent_size = 2

[*.{yml,yaml,json,jsonc,toml}]
indent_style = space
indent_size = 2

# Markdown list continuation indent is marker-width-driven (3 spaces
# under "1. "), not a fixed size. Leave indent size unenforced.
[*.md]
indent_style = space
indent_size = unset

[*.typ]
indent_style = space
indent_size = 2

[justfile]
indent_style = space
indent_size = 4
